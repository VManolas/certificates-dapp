{
  "name": "zkcredentials-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for zkSync Educational Credential Verification Platform",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:dev": "hardhat run scripts/deploy-unified.ts --network hardhat",
    "deploy:dev:ultraplonk": "VERIFIER_TYPE=ultraplonk hardhat run scripts/deploy-unified.ts --network hardhat",
    "deploy:staging": "hardhat deploy-zksync --script deploy-unified.ts --network zkSyncSepoliaTestnet",
    "deploy:production": "hardhat deploy-zksync --script deploy-unified.ts --network zkSyncMainnet",
    "deploy:local": "bash scripts/deploy-local.sh",
    "deploy:local:zksync": "bash scripts/deploy-local-zksync.sh",
    "node:local": "hardhat node --hostname 127.0.0.1 --port 8545",
    "node:local:zksync": "hardhat node-zksync",
    "deploy:local:docker": "hardhat deploy-zksync --script deploy-unified.ts --network localhost",
    "verify": "hardhat verify --network zkSyncSepoliaTestnet",
    "clean": "hardhat clean"
  },
  "keywords": [
    "zksync",
    "smart-contracts",
    "credential-verification",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@matterlabs/hardhat-zksync-deploy": "^1.3.0",
    "@matterlabs/hardhat-zksync-node": "^1.5.3",
    "@matterlabs/hardhat-zksync-solc": "^1.1.4",
    "@matterlabs/hardhat-zksync-upgradable": "^1.4.1",
    "@matterlabs/hardhat-zksync-verify": "^1.4.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.0",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.5",
    "zksync-ethers": "^6.7.0"
  },
  "dependencies": {
    "@aztec/bb.js": "0.63.1",
    "@noir-lang/noir_js": "^1.0.0-beta.0",
    "circomlibjs": "^0.1.7"
  }
}
